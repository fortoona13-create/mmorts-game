{\n  \"name\": \"mmorts-server\",\n  \"version\": \"1.0.0\",\n  \"description\": \"MMORTS Game Server - Modern Geopolitics\",\n  \"main\": \"dist/app.js\",\n  \"scripts\": {\n    \"dev\": \"ts-node src/app.ts\",\n    \"build\": \"tsc\",\n    \"start\": \"node dist/app.js\",\n    \"db:init\": \"node -e \\\"require('dotenv').config(); const fs = require('fs'); const pg = require('pg'); const client = new pg.Client(process.env.DATABASE_URL); client.connect().then(() => client.query(fs.readFileSync('./schema.sql', 'utf8'))).then(() => { console.log('DB initialized'); process.exit(0); }).catch(e => { console.error(e); process.exit(1); });\\\"\"\n  },\n  \"dependencies\": {\n    \"bcrypt\": \"^5.1.1\",\n    \"bull\": \"^4.11.5\",\n    \"cors\": \"^2.8.5\",\n    \"dotenv\": \"^16.3.1\",\n    \"express\": \"^4.18.2\",\n    \"jsonwebtoken\": \"^9.1.2\",\n    \"pg\": \"^8.11.3\",\n    \"socket.io\": \"^4.7.2\",\n    \"uuid\": \"^9.0.1\"\n  },\n  \"devDependencies\": {\n    \"@types/express\": \"^4.17.21\",\n    \"@types/node\": \"^20.10.6\",\n    \"typescript\": \"^5.3.3\",\n    \"ts-node\": \"^10.9.2\"\n  }\n}\n